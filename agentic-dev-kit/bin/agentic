#!/usr/bin/env bash
# ============================================================================
# agentic — Agentic Dev Kit CLI
# Usage: agentic <command> [options]
# ============================================================================

set -euo pipefail

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KIT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# ─── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Usage ───────────────────────────────────────────────────
usage() {
    cat <<EOF
${BOLD}agentic${NC} v${VERSION} — Agentic Dev Kit CLI

${BOLD}USAGE:${NC}
    agentic <command> [options]

${BOLD}COMMANDS:${NC}
    init [path]       初始化项目（复制 AGENT.md + .agent/ 到目标路径）
    validate [path]   运行框架结构验证
    health [path]     运行健康检查
    stress-test [path] 运行量化评分
    version           显示版本信息
    help              显示本帮助

${BOLD}EXAMPLES:${NC}
    agentic init ./my-project
    agentic validate
    agentic health .
    agentic stress-test

EOF
}

# ─── Commands ────────────────────────────────────────────────
cmd_init() {
    local target="${1:-.}"
    target="$(cd "$target" 2>/dev/null && pwd || mkdir -p "$target" && cd "$target" && pwd)"

    echo -e "${BOLD}${CYAN}🚀 Initializing Agentic Dev Kit in: ${target}${NC}"
    echo ""

    # Check if already initialized
    if [ -f "$target/AGENT.md" ] && [ -d "$target/.agent" ]; then
        echo -e "${RED}⚠️  目标路径已有 AGENT.md 和 .agent/，跳过初始化以防覆盖。${NC}"
        echo "    如需重新初始化，请先删除目标路径的 AGENT.md 和 .agent/"
        exit 1
    fi

    # Copy AGENT.md
    if [ -f "$KIT_DIR/AGENT.md" ]; then
        cp "$KIT_DIR/AGENT.md" "$target/AGENT.md"
        echo -e "  ${GREEN}✅${NC} AGENT.md copied"
    else
        echo -e "  ${RED}❌${NC} AGENT.md not found in kit directory"
        exit 1
    fi

    # Copy .agent directory
    if [ -d "$KIT_DIR/.agent" ]; then
        cp -r "$KIT_DIR/.agent" "$target/.agent"
        echo -e "  ${GREEN}✅${NC} .agent/ directory copied"
    else
        echo -e "  ${RED}❌${NC} .agent/ directory not found in kit directory"
        exit 1
    fi

    # Add AGENT.local.md to .gitignore if git repo
    if [ -d "$target/.git" ]; then
        if ! grep -q "AGENT.local.md" "$target/.gitignore" 2>/dev/null; then
            echo "AGENT.local.md" >> "$target/.gitignore"
            echo -e "  ${GREEN}✅${NC} Added AGENT.local.md to .gitignore"
        fi
    fi

    echo ""
    echo -e "${GREEN}${BOLD}🎉 初始化完成！${NC}"
    echo "    下一步：打开项目，在聊天框输入 /init 让 AI 扫描项目"
}

cmd_validate() {
    local target="${1:-.}"
    bash "$KIT_DIR/.agent/scripts/validate-structure.sh" "$target"
}

cmd_health() {
    local target="${1:-.}"
    bash "$KIT_DIR/.agent/scripts/health-check.sh" "$target"
}

cmd_stress_test() {
    local target="${1:-.}"
    bash "$KIT_DIR/.agent/scripts/stress-test-engine.sh" "$target"
}

cmd_version() {
    echo "agentic v${VERSION}"
    echo "Agentic Dev Kit — 可移植 AI 开发规范套件"
}

# ─── Router ──────────────────────────────────────────────────
case "${1:-help}" in
    init)       shift; cmd_init "$@" ;;
    validate)   shift; cmd_validate "$@" ;;
    health)     shift; cmd_health "$@" ;;
    stress-test) shift; cmd_stress_test "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help) usage ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        usage
        exit 1
        ;;
esac
